{
  "id": "completion",
  "name": "Completion Certificate",
  "productType": "certificate",
  "preview": "preview.jpg",

  "data": {
    "document": [
      {
        "key": "date",
        "label": "Completion Date",
        "type": "text",
        "default": "June 12, 2026"
      }
    ],

    "roster": {
      "label": "Students",
      "itemLabel": "Student",

      "fields": [
        {
          "key": "fullName",
          "label": "Full Name",
          "type": "text",
          "default": "First Last"
        },

        {
          "key": "profilePicture",
          "label": "Profile Picture",
          "type": "image",
          "default": "assets/resources/portrait.png"
        }
      ]
    }
  },

  "document": {
    "width": 11,
    "height": 8.5,
    "dpi": 200,
    "output": "pdf",

    "placement": {
      "type": "single",
      "maxRosterPerPage": 1,

      "slots": [
        {
          "x": 0,
          "y": 0,
          "w": 11,
          "h": 8.5,
          "anchor": "topLeft"
        }
      ]
    },

    "elements": [
      {
        "type": "image",
        "source": "background.jpg",
        "x": 0,
        "y": 0,
        "w": 11,
        "h": 8.5,
        "anchor": "topLeft"
      },

      {
        "type": "text",
        "source": "date",
        "x": 6,
        "y": 6.8,
        "w": 1.875,
        "h": 0.4,
        "anchor": "topLeft",
        "align": "left",
        "fontSize": 0.25,
        "fontFamily": "Times New Roman",
        "fontStyle": "italic",
        "color": "#000000"
      }
    ]
  },

  "roster": {
    "width": 11,
    "height": 8.5,

    "elements": [
      {
        "type": "text",
        "source": "fullName",
        "x": 5.5,
        "y": 4.0,
        "w": 9,
        "h": 0.75,
        "anchor": "topCenter",
        "align": "center",
        "fontSize": 0.75,
        "fontFamily": "Times New Roman",
        "color": "#275075"
      }
    ]
  }
}